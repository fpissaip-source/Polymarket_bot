POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_PROXY_ADDRESS=0xYOUR_PROXY_ADDRESS_HERE
BANKROLL=25.00

# Risk management
MAX_OPEN_TRADES=5
MAX_POSITION_HOLD_MINUTES=20.0
MAX_TOTAL_EXPOSURE_PCT=0.85
MIN_BANKROLL_FLOOR=3.0

# Gemini API (for event market sentiment analysis + live Google Search grounding)
# Model used: gemini-3-flash (fast, Google Search grounded, March 2026)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Only trade when Gemini confidence >= this threshold (0.75 = 75%)
GEMINI_MIN_CONFIDENCE=0.75

# Copy-trading: follow top polybot-arena.com bots (comma-separated proxy wallet addresses)
# How to find an address: open polymarket.com/@<username> and copy the 0x address
# Known top bots (Mar 2026):
#   BoneReader    → polymarket.com/@BoneReader    (+$457k, multi-timeframe)
#   vidarx        → polymarket.com/@vidarx        (+$274k, 5-min)
#   vague-sourdough → polymarket.com/@vague-sourdough (+$165k, 5-min)
COPY_TRADE_WALLETS=
